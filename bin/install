#!/usr/bin/env sh
set -eu

TOOLKIT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

case "$(uname -s)" in
  Darwin) CURSOR_USER_DIR="$HOME/Library/Application Support/Cursor/User" ;;
  Linux)  CURSOR_USER_DIR="$HOME/.config/Cursor/User" ;;
esac


cd ~/.cursor
ln -sfn "$TOOLKIT_ROOT/.cursor/settings.json" "$CURSOR_USER_DIR/settings.json"
ln -sfn "$TOOLKIT_ROOT/.cursor/rules" rules
ln -sfn "$TOOLKIT_ROOT/.cursor/worktrees.json" worktrees.json

cd ~/.claude
ln -sfn "$TOOLKIT_ROOT/.claude/CLAUDE.md" CLAUDE.md
ln -sfn "$TOOLKIT_ROOT/.claude/agents" agents
ln -sfn "$TOOLKIT_ROOT/.claude/settings.json" settings.json
ln -sfn "$TOOLKIT_ROOT/.claude/skills" skills
ln -sfn "$TOOLKIT_ROOT/.claude/statusline.sh" statusline.sh

(cd "$HOME" && npx -y skills add TheHotwireClub/hotwire_club-skills --skill hwc-stimulus-fundamentals -a claude-code) \
  || echo "Warning: could not install hwc-stimulus-fundamentals (run from \$HOME: npx skills add TheHotwireClub/hotwire_club-skills --skill hwc-stimulus-fundamentals -a claude-code)"

if [ -n "${1:-}" ]; then
  cd "$1"
  ln -sfn "$TOOLKIT_ROOT/conductor.json" conductor.json
fi
