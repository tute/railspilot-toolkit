{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(bin/rails:*)",
      "Bash(bundle exec:*)",
      "Bash(bundle install:*)",
      "Bash(cat:*)",
      "Bash(claude mcp:*)",
      "Bash(command -v:*)",
      "Bash(cp:*)",
      "Bash(diff:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git pull:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(git worktree:*)",
      "Bash(gws --help)",
      "Bash(gws auth:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(mkdir:*)",
      "Bash(mise exec:*)",
      "Bash(mise which:*)",
      "Bash(mv:*)",
      "Bash(ruby -rjson -e:*)",
      "Bash(tail:*)",
      "Bash(test:*)",
      "Bash(touch:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(xargs dirname:*)",
      "Bash(yarn test:*)",
      "WebFetch(domain:developer.atlassian.com)",
      "WebFetch(domain:docs.livekit.io)",
      "WebFetch(domain:github.com)",
      "WebSearch"
    ],
    "deny": [],
    "ask": [
      "Bash(rm:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus",
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [],
  "disabledMcpjsonServers": [],
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$(uname)\" = \"Darwin\" ]; then afplay /System/Library/Sounds/Glass.aiff; else paplay /usr/share/sounds/freedesktop/stereo/complete.oga; fi",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline.sh\""
  },
  "enabledPlugins": {
    "claudit@quickstop": true,
    "ruby-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "codebase-readiness@dgalarza-workflows": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "dgalarza-workflows": {
      "source": {
        "source": "github",
        "repo": "dgalarza/claude-code-workflows"
      }
    }
  }
}
